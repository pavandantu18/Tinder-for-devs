# =============================================================================
# .gitignore
# Project: DevMatch (Developer Tinder)
#
# WHY .env IS AT THE ROOT (and why it's here in .gitignore):
#   docker-compose.yml lives at the root. Docker Compose automatically reads
#   a file named exactly ".env" from the SAME directory as docker-compose.yml.
#   There is no config option to change this path — it's hardcoded behaviour.
#   So .env must stay at the root. It is gitignored here to keep secrets out
#   of version control. Use .env.example (committed) as the template.
# =============================================================================


# -----------------------------------------------------------------------------
# SECRETS — never commit these under any circumstances
# If .env is accidentally committed, rotate ALL secrets immediately.
# -----------------------------------------------------------------------------
.env
.env.local
.env*
.env.*.local        # e.g. .env.development.local, .env.production.local

# Google OAuth credentials (downloaded from Google Cloud Console)
credentials.json
token.json


# -----------------------------------------------------------------------------
# NODE.JS
# node_modules is always regenerated from package.json via `npm install`.
# The /** pattern catches nested node_modules (e.g. frontend/node_modules).
# -----------------------------------------------------------------------------
node_modules/
**/node_modules/

npm-debug.log*
yarn-debug.log*
yarn-error.log*
pnpm-debug.log*


# -----------------------------------------------------------------------------
# BUILD OUTPUT
# Generated by `npm run build` — always reproducible from source.
# -----------------------------------------------------------------------------
dist/
build/
**/dist/
**/build/


# -----------------------------------------------------------------------------
# VITE (frontend build tool)
# .vite/ is Vite's internal cache directory — speeds up dev builds.
# vite.config.js.timestamp-* are temp files created during hot reload.
# -----------------------------------------------------------------------------
.vite/
**/.vite/
vite.config.js.timestamp-*


# -----------------------------------------------------------------------------
# DOCKER
# .docker/ contains local Docker build cache — not part of the project.
# -----------------------------------------------------------------------------
.docker/


# -----------------------------------------------------------------------------
# LOGS
# -----------------------------------------------------------------------------
logs/
*.log
**/*.log


# -----------------------------------------------------------------------------
# TEMPORARY FILES
# .tmp/ is for intermediate processing files (per CLAUDE.md conventions).
# Always regenerable — never commit.
# -----------------------------------------------------------------------------
.tmp/


# -----------------------------------------------------------------------------
# OPERATING SYSTEM
# Files created automatically by macOS, Windows, Linux.
# -----------------------------------------------------------------------------

# macOS
.DS_Store
.AppleDouble

# Windows
Thumbs.db
Desktop.ini
$RECYCLE.BIN/

# Linux
*~


# -----------------------------------------------------------------------------
# IDE / EDITOR
# Personal editor config varies per developer — don't force your settings on others.
# Exception: VS Code extension recommendations and debug configs are useful team-wide.
# -----------------------------------------------------------------------------
.idea/
*.swp
*.swo
.vscode/settings.json
.vscode/launch.json.local

# Keep these VS Code files (useful for the whole team)
!.vscode/extensions.json
